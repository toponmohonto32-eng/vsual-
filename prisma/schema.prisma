// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  role        String   @default("strategist") // admin, manager, designer, analyst, strategist, developer, client
  avatarUrl   String?
  status      String   @default("online") // online, away, offline
  department  String?
  phone       String?
  bio         String?
  location    String?
  timezone    String   @default("America/Los_Angeles")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  tasks       Task[]
  ideas       Idea[]       @relation("IdeaSubmitter")
  activities  Activity[]
  votedIdeas  IdeaVote[]
}

model Client {
  id          String   @id @default(cuid())
  name        String
  companyName String?
  email       String?
  phone       String?
  website     String?
  industry    String?
  status      String   @default("active") // active, inactive, prospect
  logoUrl     String?
  address     String?
  city        String?
  state       String?
  country     String   @default("USA")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  campaigns   Campaign[]
  tasks       Task[]
}

model Campaign {
  id               String   @id @default(cuid())
  clientId         String
  name             String
  description      String?
  type             String   @default("social") // social, ppc, seo, email, content, video
  status           String   @default("draft") // draft, active, paused, completed, cancelled
  startDate        String?
  endDate          String?
  budget           Float    @default(0)
  spent            Float    @default(0)
  leadsGoal        Int      @default(0)
  leadsActual      Int      @default(0)
  conversionsGoal  Int      @default(0)
  conversionsActual Int     @default(0)
  roi              Float    @default(0)
  tags             String   @default("") // Comma-separated tags
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Relations
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks            Task[]
}

model Task {
  id             String    @id @default(cuid())
  campaignId     String?
  clientId       String?
  title          String
  description    String?
  status         String    @default("todo") // todo, in_progress, review, completed
  priority       String    @default("medium") // low, medium, high, urgent
  assigneeId     String?
  dueDate        String?
  completedAt    String?
  estimatedHours Float     @default(0)
  actualHours    Float     @default(0)
  tags           String    @default("") // Comma-separated tags
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  // Relations
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  client         Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignee       User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

model Idea {
  id              String   @id @default(cuid())
  title           String
  description     String?
  category        String   @default("campaign") // campaign, technology, product, process
  status          String   @default("idea") // idea, in_development, implemented, rejected
  priority        String   @default("medium")
  submittedById   String?
  assignedToId    String?
  clientId        String?
  campaignId      String?
  tags            String   @default("")
  estimatedCost   Float    @default(0)
  expectedImpact  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  submittedBy     User?    @relation("IdeaSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  votes           IdeaVote[]
}

model IdeaVote {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  createdAt DateTime @default(now())
  
  // Relations
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([ideaId, userId])
}

model Contact {
  id           String   @id @default(cuid())
  name         String
  email        String
  subject      String
  message      String
  status       String   @default("new") // new, read, replied, archived
  thankYouSent Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Activity {
  id         String   @id @default(cuid())
  userId     String
  userName   String
  action     String   // created, updated, deleted, submitted, etc.
  entityType String   // client, campaign, task, idea, contact
  entityId   String
  entityName String
  details    String?
  createdAt  DateTime @default(now())
  
  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
